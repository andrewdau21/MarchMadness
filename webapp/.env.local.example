# ─── PostgreSQL (READ-ONLY) ───────────────────────────────────────────────────
host=your-db-host
port=5432
dbname=your-database-name
user=your-db-user
password=your-db-password

# Optional: set to "true" if your DB requires SSL
DB_SSL=false

# ─── SMTP (Gmail) ─────────────────────────────────────────────────────────────
SMTP_USERNAME=ncaasalarycap@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# ─── App Phase ────────────────────────────────────────────────────────────────
# "entry_phase"  → shows the entry form at /entry  (root redirects here)
# "post_entry"   → shows leaderboard at /leaderboard (root redirects here)
UI_PHASE=entry_phase
